{
    "dataset": "KINSHIP",
    "data_path": "../data",
    "model": "MSRSCImprove",
    "regularizer": "NA",
    "optimizer": "Adam",
    "max_epochs": 200,
    "valid": 10,
    "rank": 400,
    "batch_size": 800,
    "eval_batch_size": 500,
    "reg": 0.0,
    "learning_rate": 0.001,
    "weight_decay": 0.005,
    "min_lr": 1e-05,
    "factor": 0.5,
    "patience": 5,
    "seed": 42,
    "verbose": 1,
    "do_train": true,
    "do_test": true,
    "do_save": true,
    "save_path": "./logs/",
    "model_id": "kinship_full",
    "checkpoint": "",
    "input_drop": 0.3,
    "hidden_drop": 0.1,
    "feature_map_drop": 0.4,
    "output_channel": 4,
    "k_w": 20,
    "k_h": 20,
    "active_fn": "selu",
    "init_fn": "kaiming_normal",
    "filter_size_list": [
        [
            1,
            3
        ],
        [
            3,
            3
        ],
        [
            1,
            5
        ]
    ],
    "loss_mode": "ce",
    "max_positives": 64,
    "label_smoothing": 0.0,
    "do_ce_weight": false,
    "use_router": true,
    "router_hidden": 64,
    "router_temperature": 1.0,
    "use_anchor": true,
    "anchor_topk": 8,
    "anchor_alpha": 0.25,
    "anchor_dropout": 0.1,
    "use_amp": true,
    "grad_clip": 1.0
}